# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID where markets will be sent
# Use @userinfobot to find your chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Kalshi API Configuration
# Register at https://www.kalshi.com and generate API credentials
KALSHI_API_KEY=your_api_key_here
KALSHI_API_SECRET=your_api_secret_here

# Kalshi API Base URL
# Production: https://api.kalshi.com/v1
# Sandbox: https://sandbox.kalshi.com/v1
KALSHI_BASE_URL=https://api.kalshi.com/v1

# Scheduling Configuration
# Timezone for daily market fetch (must be a valid pytz timezone)
# Examples: America/Phoenix (Sedona MST), America/New_York, UTC
TIMEZONE=America/Phoenix

# Time to send daily markets (24-hour format HH:MM)
SEND_TIME=09:00

# Database Configuration
# Path to SQLite database file
DB_PATH=./kalshi_predictions.db

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Debug mode (true/false)
DEBUG=False
