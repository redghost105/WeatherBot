# Phase 11: Environment Configuration Template
# Copy to .env and fill with real values

# Telegram Bot (Phase 11)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Kalshi API (Phase 8)
KALSHI_API_KEY_ID=your_api_key_id
KALSHI_PRIVATE_KEY_PATH=/path/to/private_key.pem

# System Configuration
SYSTEM_ENVIRONMENT=production  # development or production
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOGS_DIR=logs
REPORTS_DIR=reports

# Dashboard Configuration
DASHBOARD_HOST=127.0.0.1  # localhost only for security
DASHBOARD_PORT=8000
DASHBOARD_AUTO_REFRESH_SECONDS=15

# Trading Configuration
INITIAL_CAPITAL_CENTS=1000000
MIN_EDGE_THRESHOLD=0.05
MAX_DAILY_LOSS_PCT=-0.08
MAX_POSITION_SIZE=100

# Health Check Intervals
HEALTH_CHECK_INTERVAL_SECONDS=60
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Feature Flags
ENABLE_TELEGRAM_ALERTS=true
ENABLE_WEB_DASHBOARD=true
ENABLE_AUTO_RESTART=true
ENABLE_GRACEFUL_SHUTDOWN=true
